# ─────────────────────────────────────────────────────────────────────────────
# variables.env.example
# Copia este archivo como "variables.env" y rellena los valores reales.
# NUNCA subas variables.env al repositorio (contiene credenciales).
# ─────────────────────────────────────────────────────────────────────────────


# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Cadena de conexión completa.
# Formato: Host=<host>;Port=<puerto>;Username=<usuario>;Password=<contraseña>;Database=<nombre_db>
POSTGRESQL_CONNECTION=Host=localhost;Port=5432;Username=postgres;Password=CAMBIA_ESTO;Database=SolicitudServidoresDB


# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens. Mínimo 32 caracteres, cadena aleatoria.
# Genera una con: openssl rand -base64 48
JWT__key=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_AL_MENOS_32_CARACTERES


# ── Admin inicial ─────────────────────────────────────────────────────────────
# Usuario Administrador General que se crea automáticamente al primer arranque.
# Si el correo ya existe en la base de datos, se omite el seed.
# Después del primer arranque estas variables ya no son necesarias.
ADMIN_NOMBRE=Admin
ADMIN_APELLIDOS=General
ADMIN_EMAIL=admin@tudominio.gob.mx
ADMIN_PASSWORD=CAMBIA_ESTO_POR_UNA_CONTRASEÑA_SEGURA


# ── Usuarios demo (solo desarrollo) ──────────────────────────────────────────
# true  → crea usuarios de prueba al arrancar (admincd, admininf, etc.)
# false → NO crear usuarios demo (usar en producción)
SEED_DEMO_USERS=false


# ── SMTP (envío de correo) ────────────────────────────────────────────────────
# Servidor SMTP para enviar credenciales a usuarios nuevos.
#
# Opciones comunes:
#   Gmail:      smtp.gmail.com  puerto 587  (requiere "Contraseña de aplicación")
#   Outlook:    smtp.office365.com  puerto 587
#   Servidor propio: el que corresponda
#
# En Gmail: Cuenta → Seguridad → Verificación en dos pasos → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@tudominio.gob.mx
SMTP_PASSWORD=CONTRASEÑA_DE_APLICACION_SMTP
SMTP_FROM=correo@tudominio.gob.mx
SMTP_FROM_NAME=Sistema ATDT


# ── APIs externas (si aplica) ─────────────────────────────────────────────────
APID_USER=
APID_URL=
APIC_KEY=
APIC_URL=
